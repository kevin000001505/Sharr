# ============================================================================
# Sharr configuration — copy to `.env` and fill in per machine.
#   cp .env.example .env
# Each of the 3 friends runs the same stack with their OWN values below.
# Secrets (API keys, SSH key) never leave the box they belong to.
# ============================================================================

# ---------------------------------------------------------------------------
# Media library — scanned straight from your folders. Expected layout
# (folder names like "Title (Year)" give the best poster matches):
#
#   <DATA_DIR>/movie/<Movie Name (Year)>/<file>.mkv
#   <DATA_DIR>/tv_show/tv/<Show Name>/season1/<file>.mkv
#
# Files pulled from friends land in these same folders, so they show up in
# your own library automatically.
# ---------------------------------------------------------------------------
MOVIES_DIR=/data/movie                 # movies root inside the container
TV_DIR=/data/tv_show/tv                # TV root inside the container

# TMDB API key for posters/overviews in the library UI. Get one free:
# themoviedb.org → account → Settings → API → "API Key" (v3 auth).
# Each friend uses their own key; it never leaves this machine. Optional —
# without it the library still works, just without pictures.
TMDB_API_KEY=

# ---------------------------------------------------------------------------
# Filesystem / security
# IMPORTANT: Radarr/Sonarr and Sharr must see media at the SAME path. Radarr
# reports absolute paths (e.g. /data/movies/...) and Sharr rsyncs that exact
# path, confined to ALLOWED_BASE_DIR. Mount your media at /data in all of them.
# ---------------------------------------------------------------------------
ALLOWED_BASE_DIR=/data                 # nothing outside this dir can be sent/received
DATA_DIR=./data                        # host folder mounted to /data in containers

# ---------------------------------------------------------------------------
# Peer-to-peer (WireGuard tunnel)
# ---------------------------------------------------------------------------
WG_CONF_PATH=/wg/wg0.conf              # path to wg0.conf inside the container
SSH_KEY_PATH=/keys/wg_peer_key         # private key used for rsync-over-SSH to peers
SSH_USER=sharr                         # login user on the receiving peer's ssh sidecar
SSH_PORT=2222                          # ssh sidecar listens here (linuxserver default)
SHARR_PEER_PORT=8000                   # port each peer's Sharr API listens on (over tunnel)
PING_TIMEOUT=2.0                       # seconds; peer reachability check

# ---------------------------------------------------------------------------
# Infrastructure (defaults work with docker-compose; change only if needed)
# ---------------------------------------------------------------------------
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_QUEUE=transfers
RABBITMQ_USER=guest                    # change for anything beyond local testing
RABBITMQ_PASSWORD=guest                # change for anything beyond local testing

# ---------------------------------------------------------------------------
# Web API
# ---------------------------------------------------------------------------
APP_HOST=0.0.0.0
APP_PORT=8000
HTTP_TIMEOUT=15.0                      # seconds; timeout for peer/Radarr/Sonarr calls
# Comma-separated allowed browser origins. "*" disables credentialed CORS.
# Set to your real UI origin(s) for a hardened setup, e.g. http://10.0.0.2:8000
CORS_ORIGINS=*
