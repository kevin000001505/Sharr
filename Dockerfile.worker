FROM python:3.12-slim

RUN apt-get update && apt-get install -y --no-install-recommends \
    rsync \
    iproute2 \
    curl \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app
COPY pyproject.toml ./
RUN pip install --no-cache-dir -e .

COPY app/ ./app/

RUN useradd -m -s /bin/bash worker
USER worker

CMD ["python", "-m", "app.worker"]
